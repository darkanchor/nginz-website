{
  "name": "nginz-website",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "nginz family website — Astro static content + Cloudflare Worker API runtime",
  "scripts": {
    "dev": "bash ./scripts/dev.sh",
    "dev:site": "astro dev --host --port 4321",
    "dev:worker": "wrangler dev worker/index.ts --port 8788",
    "build": "bash ./scripts/build.sh",
    "build:worker": "wrangler deploy --dry-run worker/index.ts",
    "preview": "npm run build && wrangler dev",
    "check": "astro check",
    "check:worker": "tsc --noEmit -p worker/tsconfig.json",
    "lint": "astro check",
    "test": "bash ./scripts/test.sh",
    "test:watch": "vitest",
    "validate:modules": "bash ./scripts/validate-module-docs.sh",
    "scaffold:module": "bash ./scripts/scaffold-module-doc.sh",
    "clean": "rm -rf dist .astro .wrangler",
    "deploy": "npm run build && npx wrangler deploy --env production",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@fontsource-variable/roboto-flex": "^5.2.8",
    "@fontsource-variable/roboto-mono": "^5.2.9",
    "astro": "^5.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "@cloudflare/workers-types": "^4.20250201.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "wrangler": "^4.100.0"
  }
}
