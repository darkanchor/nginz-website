---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "The nginz family: nginx + nginz, nginz-njs, and nginz-token for HTTP infrastructure and AI gateways." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | nginz</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <a href="/" style="font-weight: 700; font-size: var(--text-xl); letter-spacing: -0.05em;">nginz<span style="color: var(--color-accent);">.</span></a>
        <nav class="site-nav">
          <a href="/products">Products</a>
          <a href="/pricing">Pricing</a>
          <a href="/docs">Docs</a>
          <a href="/blog">Blog</a>
          <a href="/about">About</a>
          <div style="display: flex; gap: var(--spacing-2); margin-left: var(--spacing-4);">
            <a href="/contact" class="btn btn-outline">Contact</a>
            <a href="/products/nginz-token" class="btn btn-primary">Get nginz-token</a>
          </div>
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer class="site-footer">
        <div>
          <h4 style="font-size: var(--text-base); margin-bottom: var(--spacing-4);">nginz</h4>
          <p class="muted" style="font-size: var(--text-sm);">
            The modern Zig-based platform for nginx infrastructure. Core modules, programmable policy, and AI gateway control.
          </p>
        </div>
        <div>
          <h4 style="font-size: var(--text-base); margin-bottom: var(--spacing-4);">Products</h4>
          <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: var(--spacing-2);">
            <li><a href="/products/nginz">nginz core</a></li>
            <li><a href="/products/nginz-njs">nginz-njs</a></li>
            <li><a href="/products/nginz-token">nginz-token</a></li>
            <li><a href="/pricing">Pricing</a></li>
          </ul>
        </div>
        <div>
          <h4 style="font-size: var(--text-base); margin-bottom: var(--spacing-4);">Developers</h4>
          <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: var(--spacing-2);">
            <li><a href="/docs">Documentation</a></li>
            <li><a href="https://github.com/nginz-project" target="_blank" rel="noopener">GitHub</a></li>
            <li><a href="/llms.txt">Agent Docs (llms.txt)</a></li>
          </ul>
        </div>
        <div>
          <h4 style="font-size: var(--text-base); margin-bottom: var(--spacing-4);">Company</h4>
          <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: var(--spacing-2);">
            <li><a href="/about">About</a></li>
            <li><a href="/blog">Blog</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </div>
      </footer>
    </div>
  </body>
</html>
