---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  siteName?: string;
}

const { title, description = "The nginz family: nginx + nginz, nginz-njs, and nginz-token for HTTP infrastructure and AI gateways.", siteName = "darkanchor" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | {siteName}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Blocking theme script: must run before first paint to prevent flash -->
    <script is:inline>
      (function() {
        var theme = localStorage.getItem('nginz-theme');
        if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <a href="/" class="site-logo"><img src="/icons/logo.png" alt="nginz" class="site-logo-icon" /></a>
        <nav class="site-nav">
          <a href="/products">Products</a>
          <a href="/docs">Docs</a>
          <a href="/blogs">Blogs</a>
          <div class="header-actions">
            <button class="theme-toggle" aria-label="Toggle theme" id="theme-toggle">
              <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
              <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
            </button>
            <a href="/contact" class="btn btn-secondary">Contact</a>
            <a href="/products/nginz-token" class="btn btn-primary">Get nginz-token</a>
          </div>
        </nav>
      </header>

      <main class="site-main">
        <slot />
      </main>
    </div>

    <footer class="site-footer">
      <div class="site-shell">
        <div class="footer-grid">
          <div>
            <h4>darkanchor <span style="font-weight: 400; color: var(--color-text-secondary);">— The infra anchor of the AI era</span></h4>
            <p class="footer-desc">The nginz family is a product portfolio of darkanchor — native modules, scripted policy, and AI gateway control, all running on stock nginx.</p>
            <p class="footer-icp" id="icp-com" style="display: none; font-size: var(--text-xs); color: var(--color-text-tertiary); margin-top: var(--sp-2);"><a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener" style="color: inherit;">沪ICP备2024057943号-4</a></p>
            <p class="footer-icp" id="icp-cn" style="display: none; font-size: var(--text-xs); color: var(--color-text-tertiary); margin-top: var(--sp-2);"><a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener" style="color: inherit;">沪ICP备2024057943号-2</a></p>
          </div>
          <div>
            <h4>Products</h4>
            <ul>
              <li><a href="/products/nginz">nginz</a></li>
              <li><a href="/products/nginz-njs">nginz-njs</a></li>
              <li><a href="/products/nginz-token">nginz-token</a></li>
            </ul>
          </div>
          <div>
            <h4>Developers</h4>
            <ul>
              <li><a href="https://github.com/darkanchor" target="_blank" rel="noopener">GitHub</a></li>
              <li><a href="/llms.txt">Agent Docs</a></li>
              <li><a href="/docs">Documentation</a></li>
            </ul>
          </div>
          <div>
            <h4>Subscribe</h4>
            <ul>
              <li><a href="https://checkout.darkanchor.com" target="_blank" rel="noopener">Pricing</a></li>
              <li><a href="https://checkout.darkanchor.com/subscribe#refunds" target="_blank" rel="noopener">Refund Policy</a></li>
              <li><a href="https://checkout.darkanchor.com/subscribe#terms" target="_blank" rel="noopener">Terms of Service</a></li>
            </ul>
          </div>
        </div>
      </div>
    </footer>

    <script is:inline>
      // Theme toggle (initial class already set in <head>, no flash)
      document.getElementById('theme-toggle').addEventListener('click', function() {
        var html = document.documentElement;
        var isDark = html.classList.contains('dark');
        if (isDark) {
          html.classList.remove('dark');
          localStorage.setItem('nginz-theme', 'light');
        } else {
          html.classList.add('dark');
          localStorage.setItem('nginz-theme', 'dark');
        }
      });
    </script>

    <script is:inline>
      // Show ICP备案号 on darkanchor.com.cn
      if (window.location.hostname === 'darkanchor.com.cn') {
        var el = document.getElementById('icp-cn');
        if (el) el.style.display = '';
      }
    </script>
    <script is:inline>
      // Copy-to-clipboard for code blocks
      document.querySelectorAll('pre').forEach(function(pre) {
        var btn = document.createElement('button');
        btn.className = 'code-copy-btn';
        btn.title = 'Copy';
        btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
        pre.style.position = 'relative';
        pre.appendChild(btn);
        btn.addEventListener('click', function() {
          var code = pre.querySelector('code');
          var text = code ? code.textContent : pre.textContent;
          navigator.clipboard.writeText(text).then(function() {
            btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
            btn.classList.add('copied');
            setTimeout(function() {
              btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
              btn.classList.remove('copied');
            }, 1500);
          });
        });
      });
    </script>
  </body>
</html>