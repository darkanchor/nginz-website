---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = await getCollection("blog");
---

<BaseLayout title="Blog" siteName="darkanchor">
  <section class="page-header">
    <h1>Blog</h1>
    <p class="muted">Technical content and product updates.</p>
  </section>

  {posts.length === 0 && <p class="muted">No posts yet.</p>}

  <section class="card-grid" style="grid-template-columns: 1fr;">
    {posts.map((post: CollectionEntry<"blog">) => (
      <a href={`/blog/${post.slug}`} style="text-decoration: none; color: inherit;">
        <article class="card" style="display: flex; justify-content: space-between; align-items: center;">
          <div>
            <h3 style="margin-bottom: var(--sp-1);">{post.data.title}</h3>
            {post.data.description && <p class="muted" style="font-size: var(--text-sm); margin: 0;">{post.data.description}</p>}
          </div>
          {post.data.date && (
            <time datetime={post.data.date.toISOString()} class="muted" style="font-size: var(--text-sm); white-space: nowrap; margin-left: var(--sp-4);">
              {post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
            </time>
          )}
        </article>
      </a>
    ))}
  </section>
</BaseLayout>