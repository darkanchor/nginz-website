---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post: CollectionEntry<'blog'>) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

type Props = {
  post: CollectionEntry<'blog'>;
};

const { post } = Astro.props;
const { Content } = await post.render();
---

<BaseLayout title={post.data.title} description={post.data.description ?? `${post.data.title} on the nginz blog.`} siteName="darkanchor">
  <article class="prose" style="max-width: 800px; margin: 0 auto; padding-bottom: var(--sp-16);">
    <Content />
  </article>
</BaseLayout>