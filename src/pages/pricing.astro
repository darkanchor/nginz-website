---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Pricing" description="nginz family pricing. Open source core, Pro policy layer, and Enterprise AI gateways.">
  <div class="page-header">
    <h1>Pricing</h1>
    <p class="muted" style="font-size: var(--text-lg); margin: 0 auto;">
      Open source where you need freedom. Paid layers where you need organizational control.
    </p>
  </div>

  <section class="section" style="padding-top: 0;">
    <div class="card-grid" style="grid-template-columns: repeat(3, 1fr); align-items: start;">

      <!-- Community -->
      <div class="card" style="padding: var(--sp-8); display: flex; flex-direction: column;">
        <span class="tag" style="margin-bottom: var(--sp-3);">Open Source</span>
        <h3>Community</h3>
        <p class="muted" style="min-height: 2.5rem;">Core nginz platform for local development and self-hosted infrastructure.</p>
        <div style="font-size: var(--text-3xl); font-weight: 700; margin: var(--sp-6) 0;">$0</div>
        <ul style="list-style: none; padding: 0; display: grid; gap: var(--sp-3); margin-bottom: var(--sp-8); flex-grow: 1;">
          <li style="display: flex; gap: var(--sp-2); align-items: start;"><span class="icon-box" style="width: 20px; height: 20px; min-width: 20px;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span> <span>Open source (MIT)</span></li>
          <li style="display: flex; gap: var(--sp-2); align-items: start;"><span class="icon-box" style="width: 20px; height: 20px; min-width: 20px;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span> <span>Core Zig modules</span></li>
          <li style="display: flex; gap: var(--sp-2); align-items: start;"><span class="icon-box" style="width: 20px; height: 20px; min-width: 20px;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span> <span>Community support</span></li>
        </ul>
        <a href="/docs" class="btn btn-secondary" style="width: 100%;">Read Docs</a>
      </div>

      <!-- Pro -->
      <div class="card" style="padding: var(--sp-8); display: flex; flex-direction: column; border-color: var(--color-accent);">
        <span class="tag tag-accent" style="margin-bottom: var(--sp-3);">Pro</span>
        <h3>Pro</h3>
        <p class="muted" style="min-height: 2.5rem;">nginz-njs policy layer for dynamic traffic control.</p>
        <div style="font-size: var(--text-3xl); font-weight: 700; margin: var(--sp-6) 0;">$49<span style="font-size: var(--text-base); font-weight: 400; color: var(--color-text-secondary);">/mo</span></div>
        <ul style="list-style: none; padding: 0; display: grid; gap: var(--sp-3); margin-bottom: var(--sp-8); flex-grow: 1;">
          <li style="display: flex; gap: var(--sp-2); align-items: start;"><span class="icon-box" style="width: 20px; height: 20px; min-width: 20px;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span> <span>Everything in Community</span></li>
          <li style="display: flex; gap: var(--sp-2); align-items: start;"><span class="icon-box" style="width: 20px; height: 20px; min-width: 20px;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span> <span>Gleam to njs compiler</span></li>
          <li style="display: flex; gap: var(--sp-2); align-items: start;"><span class="icon-box" style="width: 20px; height: 20px; min-width: 20px;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span> <span>Standard type definitions</span></li>
          <li style="display: flex; gap: var(--sp-2); align-items: start;"><span class="icon-box" style="width: 20px; height: 20px; min-width: 20px;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span> <span>Email support (48h)</span></li>
        </ul>
        <button class="btn btn-primary paddle-checkout-stub" data-plan="pro" style="width: 100%;">Buy Pro</button>
      </div>

      <!-- Enterprise -->
      <div class="card" style="padding: var(--sp-8); display: flex; flex-direction: column;">
        <span class="tag" style="margin-bottom: var(--sp-3);">Enterprise</span>
        <h3>Enterprise</h3>
        <p class="muted" style="min-height: 2.5rem;">nginz-token AI gateway and organizational control.</p>
        <div style="font-size: var(--text-3xl); font-weight: 700; margin: var(--sp-6) 0;">Custom</div>
        <ul style="list-style: none; padding: 0; display: grid; gap: var(--sp-3); margin-bottom: var(--sp-8); flex-grow: 1;">
          <li style="display: flex; gap: var(--sp-2); align-items: start;"><span class="icon-box" style="width: 20px; height: 20px; min-width: 20px;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span> <span>Everything in Pro</span></li>
          <li style="display: flex; gap: var(--sp-2); align-items: start;"><span class="icon-box" style="width: 20px; height: 20px; min-width: 20px;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span> <span>Token quota management</span></li>
          <li style="display: flex; gap: var(--sp-2); align-items: start;"><span class="icon-box" style="width: 20px; height: 20px; min-width: 20px;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span> <span>Cost visibility dashboard</span></li>
          <li style="display: flex; gap: var(--sp-2); align-items: start;"><span class="icon-box" style="width: 20px; height: 20px; min-width: 20px;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span> <span>Dedicated Slack channel</span></li>
          <li style="display: flex; gap: var(--sp-2); align-items: start;"><span class="icon-box" style="width: 20px; height: 20px; min-width: 20px;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span> <span>Custom SLA</span></li>
        </ul>
        <a href="/contact" class="btn btn-primary" style="width: 100%;">Contact Sales</a>
      </div>

    </div>
  </section>

  <section class="section">
    <div class="section-title">
      <h2>Feature Comparison</h2>
    </div>
    <table class="matrix-table">
      <thead>
        <tr>
          <th>Feature</th>
          <th>Community</th>
          <th>Pro</th>
          <th>Enterprise</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Core Zig modules</td>
          <td>✓</td>
          <td>✓</td>
          <td>✓</td>
        </tr>
        <tr>
          <td>Gleam → njs compiler</td>
          <td>—</td>
          <td>✓</td>
          <td>✓</td>
        </tr>
        <tr>
          <td>Type-safe policy engine</td>
          <td>—</td>
          <td>✓</td>
          <td>✓</td>
        </tr>
        <tr>
          <td>AI Gateway token quotas</td>
          <td>—</td>
          <td>—</td>
          <td>✓</td>
        </tr>
        <tr>
          <td>Cost visibility dashboard</td>
          <td>—</td>
          <td>—</td>
          <td>✓</td>
        </tr>
        <tr>
          <td>Support SLA</td>
          <td>Community</td>
          <td>48h Email</td>
          <td>Custom / Slack</td>
        </tr>
      </tbody>
    </table>
  </section>

  <script>
    document.querySelectorAll('.paddle-checkout-stub').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        alert('Paddle checkout integration will be mounted here.');
      });
    });
  </script>
</BaseLayout>