---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Pricing" description="nginz family pricing. Open source core, Pro policy layer, and Enterprise AI gateways.">
  <div class="page-header" style="text-align: center; margin-bottom: var(--spacing-12);">
    <h1>Pricing</h1>
    <p class="prose muted" style="margin: 0 auto; font-size: var(--text-lg);">
      Open source where you need freedom. Paid layers where you need organizational control.
    </p>
  </div>

  <section class="section" style="padding-top: 0;">
    <div class="card-grid" style="grid-template-columns: repeat(3, 1fr); align-items: start;">
      
      <!-- Community -->
      <div class="card" style="padding: var(--spacing-8);">
        <h3 style="margin-bottom: var(--spacing-2);">Community</h3>
        <p class="muted" style="min-height: 3rem;">Core nginz platform for local development and self-hosted infrastructure.</p>
        <div style="font-size: var(--text-3xl); font-weight: 700; margin: var(--spacing-6) 0;">$0</div>
        <ul style="list-style: none; padding: 0; display: grid; gap: var(--spacing-3); margin-bottom: var(--spacing-8); flex-grow: 1;">
          <li style="display: flex; gap: var(--spacing-2);"><strong style="color: var(--color-accent);">✓</strong> Open source (MIT)</li>
          <li style="display: flex; gap: var(--spacing-2);"><strong style="color: var(--color-accent);">✓</strong> Core Zig modules</li>
          <li style="display: flex; gap: var(--spacing-2);"><strong style="color: var(--color-accent);">✓</strong> Community support</li>
        </ul>
        <a href="/docs" class="btn btn-outline" style="width: 100%;">Read Docs</a>
      </div>

      <!-- Pro -->
      <div class="card" style="padding: var(--spacing-8); border-color: var(--color-slate); box-shadow: var(--shadow-md);">
        <h3 style="margin-bottom: var(--spacing-2);">Pro</h3>
        <p class="muted" style="min-height: 3rem;">nginz-njs policy layer for dynamic traffic control.</p>
        <div style="font-size: var(--text-3xl); font-weight: 700; margin: var(--spacing-6) 0;">$49<span style="font-size: var(--text-base); font-weight: 400; color: var(--color-text-muted);">/mo</span></div>
        <ul style="list-style: none; padding: 0; display: grid; gap: var(--spacing-3); margin-bottom: var(--spacing-8); flex-grow: 1;">
          <li style="display: flex; gap: var(--spacing-2);"><strong style="color: var(--color-accent);">✓</strong> Everything in Community</li>
          <li style="display: flex; gap: var(--spacing-2);"><strong style="color: var(--color-accent);">✓</strong> Gleam to njs compiler</li>
          <li style="display: flex; gap: var(--spacing-2);"><strong style="color: var(--color-accent);">✓</strong> Standard type definitions</li>
          <li style="display: flex; gap: var(--spacing-2);"><strong style="color: var(--color-accent);">✓</strong> Email support (48h)</li>
        </ul>
        <!-- Paddle stub -->
        <button class="btn btn-primary paddle-checkout-stub" data-plan="pro" style="width: 100%;">Buy Pro</button>
      </div>

      <!-- Enterprise -->
      <div class="card" style="padding: var(--spacing-8); border-color: var(--color-accent); background: var(--color-paper);">
        <h3 style="margin-bottom: var(--spacing-2);">Enterprise</h3>
        <p class="muted" style="min-height: 3rem;">nginz-token AI gateway and organizational control.</p>
        <div style="font-size: var(--text-3xl); font-weight: 700; margin: var(--spacing-6) 0;">Custom</div>
        <ul style="list-style: none; padding: 0; display: grid; gap: var(--spacing-3); margin-bottom: var(--spacing-8); flex-grow: 1;">
          <li style="display: flex; gap: var(--spacing-2);"><strong style="color: var(--color-accent);">✓</strong> Everything in Pro</li>
          <li style="display: flex; gap: var(--spacing-2);"><strong style="color: var(--color-accent);">✓</strong> Token quota management</li>
          <li style="display: flex; gap: var(--spacing-2);"><strong style="color: var(--color-accent);">✓</strong> Cost visibility dashboard</li>
          <li style="display: flex; gap: var(--spacing-2);"><strong style="color: var(--color-accent);">✓</strong> Dedicated Slack channel</li>
          <li style="display: flex; gap: var(--spacing-2);"><strong style="color: var(--color-accent);">✓</strong> Custom SLA</li>
        </ul>
        <a href="/contact" class="btn btn-primary" style="width: 100%;">Contact Sales</a>
      </div>

    </div>
  </section>

  <section class="section">
    <div class="section-title">
      <h2>Feature Comparison</h2>
    </div>
    <table class="matrix-table">
      <thead>
        <tr>
          <th>Feature</th>
          <th>Community</th>
          <th>Pro</th>
          <th>Enterprise</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Core zig modules</td>
          <td>✓</td>
          <td>✓</td>
          <td>✓</td>
        </tr>
        <tr>
          <td>Gleam -> njs compiler</td>
          <td>-</td>
          <td>✓</td>
          <td>✓</td>
        </tr>
        <tr>
          <td>Type-safe policy engine</td>
          <td>-</td>
          <td>✓</td>
          <td>✓</td>
        </tr>
        <tr>
          <td>AI Gateway token quotas</td>
          <td>-</td>
          <td>-</td>
          <td>✓</td>
        </tr>
        <tr>
          <td>Cost visibility dashboard</td>
          <td>-</td>
          <td>-</td>
          <td>✓</td>
        </tr>
        <tr>
          <td>Support SLA</td>
          <td>Community</td>
          <td>48h Email</td>
          <td>Custom / Slack</td>
        </tr>
      </tbody>
    </table>
  </section>

  <script>
    // Paddle integration stub
    document.querySelectorAll('.paddle-checkout-stub').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        alert('Paddle checkout integration will be mounted here.');
      });
    });
  </script>
</BaseLayout>
