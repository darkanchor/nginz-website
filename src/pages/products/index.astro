---
import BaseLayout from "../../layouts/BaseLayout.astro";

const products = [
  {
    href: "/products/nginz",
    tag: "Open Source",
    tagClass: "",
    title: "nginz core",
    desc: "The foundational Zig-based nginx module platform.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5Z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
    features: ["High-performance Zig core", "Native nginx integration", "Memory-safe memory pools", "Docker-ready deployments"],
    btnLabel: "View Core Platform",
    btnClass: "btn-secondary",
  },
  {
    href: "/products/nginz-njs",
    tag: "Pro",
    tagClass: "tag-mint",
    title: "nginz-njs",
    desc: "Programmable policy layer compiling Gleam to njs.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
    features: ["Type-safe Gleam DSL", "Dynamic request handling", "Custom auth integrations", "Advanced traffic shaping"],
    btnLabel: "Explore Policy Engine",
    btnClass: "btn-primary",
  },
  {
    href: "/products/nginz-token",
    tag: "Enterprise",
    tagClass: "tag-mint",
    title: "nginz-token",
    desc: "AI Gateway and control layer for the entire org.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`,
    features: ["Global token quotas", "LLM provider routing", "Cost visibility dashboards", "Organizational security controls"],
    btnLabel: "View AI Gateway",
    btnClass: "btn-primary",
  },
];

const checkIcon = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;
---

<BaseLayout title="Products" description="The nginz product family. Core infrastructure, programmable policy, and AI gateway control.">
  <div class="page-header">
    <h1>Product Family</h1>
    <p class="muted" style="font-size: var(--text-lg); margin: 0 auto;">
      Open-source foundation. Paid layers that solve organizational problems.
    </p>
  </div>

  <section class="section" style="padding-top: 0;">
    <div style="display: grid; gap: var(--sp-6); grid-template-columns: 1fr;">

      {products.map((p) => (
        <div class="card" style={`display: grid; grid-template-columns: 1fr 2fr; gap: var(--sp-8); align-items: center; padding: var(--sp-8);`}>
          <div>
            <div style="display: flex; align-items: center; gap: var(--sp-3); margin-bottom: var(--sp-3);">
              <div class="icon-box">
                <Fragment set:html={p.icon} />
              </div>
              <span class={`tag ${p.tagClass}`}>{p.tag}</span>
            </div>
            <h2 style="margin-bottom: var(--sp-2);">{p.title}</h2>
            <p class="muted">{p.desc}</p>
            <a href={p.href} class={`btn ${p.btnClass}`} style="margin-top: var(--sp-4);">{p.btnLabel}</a>
          </div>
          <div class="feature-box">
            <ul style="list-style: none; padding: 0; display: grid; gap: var(--sp-3); margin: 0;">
              {p.features.map((f) => (
                <li style="display: flex; gap: var(--sp-2); align-items: start;">
                  <span class="icon-box" style="width: 20px; height: 20px; min-width: 20px;">
                    <Fragment set:html={checkIcon} />
                  </span>
                  <span>{f}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}

    </div>
  </section>
</BaseLayout>