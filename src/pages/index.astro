---
import BaseLayout from "../layouts/BaseLayout.astro";

const products = [
  {
    href: "/products/nginz",
    tag: "Open Source",
    title: "nginz",
    desc: "Core Zig nginx module platform. The high-performance foundation for modern HTTP routing.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5Z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
  },
  {
    href: "/products/nginz-njs",
    tag: "Pro",
    tagAccent: true,
    title: "nginz-njs",
    desc: "Programmable policy layer. Write type-safe Gleam that compiles to njs for dynamic request handling.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  },
  {
    href: "/products/nginz-token",
    tag: "Enterprise",
    tagAccent: true,
    title: "nginz-token",
    desc: "Paid AI gateway and control layer. Manage token quotas, model routing, and cost visibility across your org.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`,
  },
];
---

<BaseLayout title="HTTP Infrastructure & AI Gateways" siteName="darkanchor">
  <section style="padding: var(--sp-16) 0 var(--sp-12); text-align: center; max-width: 800px; margin: 0 auto;">
    <h1 style="margin-bottom: var(--sp-4);">
      Run nginx + nginz for HTTP infrastructure.
    </h1>
    <p class="muted" style="font-size: var(--text-lg); margin: 0 auto var(--sp-8); max-width: 600px;">
      Add nginz-token for AI gateway control.
    </p>
    <p style="max-width: 600px; margin: 0 auto var(--sp-8); color: var(--color-text-secondary); line-height: 1.6;">
      The nginz family provides a core Zig nginx module platform, programmable Gleam policy layers, and an enterprise-ready AI gateway for cost visibility and operational management.
    </p>
    <div style="display: flex; gap: var(--sp-3); justify-content: center;">
      <a href="/products/nginz-token" class="btn btn-primary">Explore nginz-token</a>
      <a href="/docs" class="btn btn-secondary">Read Documentation</a>
    </div>
  </section>

  <section class="section">
    <div class="section-title">
      <h2>The nginz Family</h2>
      <p class="muted">From open-source core to enterprise control layers.</p>
    </div>

    <div class="card-grid">
      {products.map((p) => (
        <a href={p.href} style="text-decoration: none; color: inherit; display: block; height: 100%;">
          <div class="card">
            <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: var(--sp-4);">
              <div class="icon-box">
                <Fragment set:html={p.icon} />
              </div>
              <span class={`tag${p.tagAccent ? ' tag-mint' : ''}`}>{p.tag}</span>
            </div>
            <h3>{p.title}</h3>
            <p>{p.desc}</p>
            <div style="margin-top: var(--sp-4); display: flex; align-items: center; gap: var(--sp-1); font-weight: 500; font-size: var(--text-sm); color: var(--brand-mint);">
              View {p.title === 'nginz' ? 'Platform' : p.title === 'nginz-njs' ? 'Policy Engine' : 'AI Gateway'} <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="section" style="padding: var(--sp-16) 0;">
    <div style="max-width: 800px; margin: 0 auto; text-align: center;">
      <h2 style="margin-bottom: var(--sp-4);">Ready for production?</h2>
      <p class="muted" style="font-size: var(--text-lg); margin-bottom: var(--sp-8);">
        Start locally with the open-source core, or deploy nginz-token for immediate AI gateway protection.
      </p>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-4); text-align: left;">
        <div class="feature-box">
          <h4 style="margin-bottom: var(--sp-2);">Try Locally</h4>
          <p style="font-size: var(--text-sm); margin-bottom: var(--sp-3);">Pull the Docker image and start routing in seconds.</p>
          <pre style="margin: 0; padding: var(--sp-3); font-size: var(--text-xs);"><code>docker pull ghcr.io/nginz-project/nginz</code></pre>
        </div>
        <div class="feature-box">
          <h4 style="margin-bottom: var(--sp-2);">Contact Sales</h4>
          <p style="font-size: var(--text-sm); margin-bottom: var(--sp-3);">Discuss enterprise volume and custom integrations.</p>
          <a href="/contact" class="btn btn-primary" style="width: 100%;">Get in Touch</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>