---
import BaseLayout from "../layouts/BaseLayout.astro";

const products = [
  {
    href: "/products/nginz",
    tag: "Free",
    title: "nginz",
    desc: "Native modules for stock nginx — active health checks, dynamic upstreams, JWT auth, Prometheus metrics, and more. No fork, no patch, no Plus license.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5Z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
  },
  {
    href: "/products/nginz-njs",
    tag: "Free",
    title: "nginz-njs",
    desc: "Scripted policy layer running in nginx njs. Compose authorization, feature flags, workflow orchestration, and response transforms — testable, reusable, no second runtime.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  },
  {
    href: "/products/nginz-token",
    tag: "Paid",
    tagAccent: true,
    title: "nginz-token",
    desc: "AI gateway that runs inside your nginx binary. Token-level rate limiting, per-user cost tracking, semantic caching, and prompt security — no SaaS proxy, your data stays yours.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`,
  },
];
---

<BaseLayout title="nginx Infrastructure &amp; AI Gateway — Stock nginx, No Fork" siteName="darkanchor">
  <section style="padding: var(--sp-16) 0 var(--sp-12); text-align: center; max-width: 800px; margin: 0 auto;">
    <h1 style="margin-bottom: var(--sp-4);">
      NGINX Plus features, free.<br />AI gateway, inside your nginx.
    </h1>
    <p style="max-width: 640px; margin: 0 auto var(--sp-8); color: var(--color-text-secondary); line-height: 1.6; font-size: var(--text-lg);">
      Active health checks, dynamic upstreams, sticky sessions, JWT/OIDC auth, Prometheus metrics, WAF — everything you'd pay NGINX Plus for, running on stock nginx with zero patches. Add nginz-token when you need token-level visibility and control over your LLM APIs.
    </p>
    <div style="display: flex; gap: var(--sp-3); justify-content: center;">
      <a href="/products/nginz-token" class="btn btn-primary">Explore nginz-token</a>
      <a href="/docs" class="btn btn-secondary">Read Documentation</a>
    </div>
  </section>

  <section class="section">
    <div class="section-title">
      <h2>Three layers. One nginx binary.</h2>
      <p class="muted">Drop in what you need. Everything loads into stock nginx via standard <code>--add-module</code> or <code>load_module</code>.</p>
    </div>

    <div class="card-grid">
      {products.map((p) => (
        <a href={p.href} style="text-decoration: none; color: inherit; display: block; height: 100%;">
          <div class="card">
            <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: var(--sp-4);">
              <div class="icon-box">
                <Fragment set:html={p.icon} />
              </div>
              <span class={`tag${p.tagAccent ? ' tag-mint' : ''}`}>{p.tag}</span>
            </div>
            <h3>{p.title}</h3>
            <p>{p.desc}</p>
            <div style="margin-top: var(--sp-4); display: flex; align-items: center; gap: var(--sp-1); font-weight: 500; font-size: var(--text-sm); color: var(--brand-mint);">
              Learn more <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="section" style="padding: var(--sp-16) 0;">
    <div style="max-width: 800px; margin: 0 auto; text-align: center;">
      <h2 style="margin-bottom: var(--sp-4);">Start today</h2>
      <p class="muted" style="font-size: var(--text-lg); margin-bottom: var(--sp-8);">
        Pull the open-source Docker image, or talk to us about nginz-token for your team.
      </p>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-4); text-align: left;">
        <div class="feature-box">
          <h4 style="margin-bottom: var(--sp-2);">Open Source</h4>
          <p style="font-size: var(--text-sm); margin-bottom: var(--sp-3);">39 modules, Apache 2.0. Runs on stock nginx with no patches.</p>
          <a href="/docs" class="btn btn-secondary" style="width: 100%;">Read the Docs</a>
        </div>
        <div class="feature-box">
          <h4 style="margin-bottom: var(--sp-2);">AI Gateway</h4>
          <p style="font-size: var(--text-sm); margin-bottom: var(--sp-3);">Token-level control for your LLM APIs. Pro and Enterprise tiers available.</p>
          <a href="/contact" class="btn btn-primary" style="width: 100%;">Talk to Us</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>